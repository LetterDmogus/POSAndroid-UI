<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="12dp">

        <ImageView
            android:id="@+id/ivBarang"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="#F0F0F0"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvNamaBarang"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Nama Barang"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivBarang" />

        <TextView
            android:id="@+id/tvSku"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SKU: BRG-001"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            app:layout_constraintStart_toStartOf="@id/tvNamaBarang"
            app:layout_constraintTop_toBottomOf="@id/tvNamaBarang" />

        <TextView
            android:id="@+id/tvHarga"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Rp 15.000"
            android:textColor="@color/pos_blue_dark"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tvNamaBarang"
            app:layout_constraintTop_toBottomOf="@id/tvSku" />

        <TextView
            android:id="@+id/tvStok"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stok: 10"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            app:layout_constraintBottom_toBottomOf="@id/tvHarga"
            app:layout_constraintEnd_toEndOf="@id/tvNamaBarang" />

        <!-- Tombol Tambah ke Keranjang Cepat -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddQuick"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="4dp"
            android:backgroundTint="@color/pos_blue_dark"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            app:cornerRadius="20dp"
            app:icon="@android:drawable/ic_input_add"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="20dp"
            app:iconTint="@color/white"
            app:layout_constraintBottom_toBottomOf="@id/ivBarang"
            app:layout_constraintEnd_toEndOf="@id/ivBarang"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>